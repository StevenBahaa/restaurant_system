<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="restaurant_branch_view_search" model="ir.ui.view">
        <field name="name">restaurant.branch.view.search</field>
        <field name="model">restaurant.branch</field>
        <field name="arch" type="xml">
            <search string="Search Branches">
                <field name="name"/>
                <field name="code"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List (formerly Tree) View -->
    <record id="restaurant_branch_view_list" model="ir.ui.view">
        <field name="name">restaurant.branch.view.list</field>
        <field name="model">restaurant.branch</field>
        <field name="arch" type="xml">
            <list string="Restaurant Branches">
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="warehouse_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="restaurant_branch_view_form" model="ir.ui.view">
        <field name="name">restaurant.branch.view.form</field>
        <field name="model">restaurant.branch</field>
        <field name="arch" type="xml">
            <form string="Restaurant Branch">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="warehouse_id"/>
                            <field name="manager_user_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Branch notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="restaurant_branch_action" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">restaurant.branch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="restaurant_branch_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define a new restaurant branch.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="restaurant_menu_branches"
        name="Branches"
        parent="restaurant_base.restaurant_menu_configuration"
        action="restaurant_branch_action"
        sequence="10"/>
</odoo>
