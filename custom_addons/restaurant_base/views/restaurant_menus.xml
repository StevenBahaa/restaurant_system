<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Root Menu -->
    <menuitem id="restaurant_root_menu"
        name="Restaurant ERP"
        sequence="10" />

    <!-- Top-level Menus -->
    <menuitem id="restaurant_products_menu"
        name="Products"
        parent="restaurant_root_menu"
        sequence="10" />

    <menuitem id="restaurant_products_submenu_products"
        name="Products"
        parent="restaurant_products_menu"
        action="product.product_template_action"
        sequence="10" />

    <menuitem id="restaurant_products_submenu_variants"
        name="Product Variants"
        parent="restaurant_products_menu"
        action="product.product_normal_action"
        sequence="20" />

    <menuitem id="restaurant_menu_configuration"
        name="Configuration"
        parent="restaurant_root_menu"
        sequence="100" />
</odoo>
