<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_restaurant" model="ir.module.category">
            <field name="name">Restaurant</field>
            <field name="description">Helps you manage your restaurant operations.</field>
            <field name="sequence">100</field>
        </record>

        <record id="group_restaurant_branch_manager" model="res.groups">
            <field name="name">Branch Manager</field>
            <field name="category_id" ref="module_category_restaurant"/>
            <field name="comment">Can manage specific branch operations.</field>
        </record>

        <record id="group_restaurant_operations_manager" model="res.groups">
            <field name="name">Operations Manager</field>
            <field name="category_id" ref="module_category_restaurant"/>
            <field name="implied_ids" eval="[(4, ref('group_restaurant_branch_manager'))]"/>
            <field name="comment">Can manage all branches and advanced restaurant operations.</field>
        </record>
    </data>
</odoo>
