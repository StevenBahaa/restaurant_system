<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_category_form_view_restaurant_menu" model="ir.ui.view">
        <field name="name">pos.category.form.restaurant.menu</field>
        <field name="model">pos.category</field>
        <field name="inherit_id" ref="point_of_sale.product_pos_category_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Restaurant Menu Configuration">
                    <field name="is_restaurant_category" />
                    <field name="show_in_pos" />
                    <field name="available_from" />
                    <field name="available_until" />
                </group>
                <group string="Menu Scheduling Rules" invisible="not is_restaurant_category">
                    <field name="category_schedule_line_ids" nolabel="1" colspan="2">
                        <list editable="bottom">
                            <field name="schedule_rule_id" options="{'no_create': True}" domain="[('company_id', 'in', (company_id, False))]"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1" force_save="1"/>
                            <field name="branch_id" options="{'no_create': True}" domain="[('company_id', '=', company_id)]"/>
                            <field name="active" widget="boolean_toggle"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>