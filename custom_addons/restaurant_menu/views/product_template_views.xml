<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view_restaurant_menu" model="ir.ui.view">
        <field name="name">product.template.form.restaurant.menu</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']/group[1]" position="after">
                <group string="Restaurant ERP">
                    <group string="Menu Identity">
                        <field name="is_menu_item" />
                        <field name="arabic_name" invisible="not is_menu_item" />
                    </group>

                    <group string="Restaurant Classification">
                        <field name="restaurant_product_type" />
                    </group>
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">

                <page string="Add-ons" name="restaurant_addons" invisible="not is_menu_item">
                    <field name="product_addon_group_ids" nolabel="1">
                        <list>
                            <field name="sequence" widget="handle" />
                            <field name="addon_group_id" string="Add-on Group"
                                readonly="used_in_operations" />
                            <field name="required" string="Required" />
                            <field name="min_selection" string="Min" />
                            <field name="max_selection" string="Max" />
                            <field name="active" string="Active" />
                        </list>

                        <form string="Product Add-on Group">
                            <sheet>
                                <group>
                                    <group>
                                        <field name="sequence" />
                                        <field name="addon_group_id" readonly="used_in_operations" />
                                        <field name="required" />
                                    </group>

                                    <group>
                                        <field name="min_selection" />
                                        <field name="max_selection" />
                                        <field name="active" />
                                    </group>
                                </group>

                                <notebook>
                                    <page string="Add-on Items">
                                        <h2>
                                            <field name="addon_group_id" readonly="1" />
                                        </h2>
                                        <field name="addon_item_ids" nolabel="1" readonly="1">
                                            <list create="0" delete="0" edit="0">
                                                <field name="product_tmpl_id" />
                                                <field name="additional_price" />
                                                <field name="max_quantity" />
                                                <field name="kitchen_note" />
                                                <field name="active" />
                                            </list>
                                        </field>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>

                </page>

                <page string="Combo Components"
                    invisible="restaurant_product_type != 'combo'">
                    <div class="alert alert-warning"
                        role="alert"
                        invisible="restaurant_product_type != 'combo' or combo_is_valid">
                        <strong>Combo Meal is not ready to sell.</strong>
                        <br />
                        <field name="combo_validation_message" readonly="1" nolabel="1" />
                    </div>

                    <div class="alert alert-danger"
                        role="alert"
                        invisible="restaurant_product_type != 'combo' or not combo_is_valid or combo_is_available">
                        <strong>Combo Meal is currently unavailable.</strong>
                        <br />
                        <field name="combo_unavailable_reason" readonly="1" nolabel="1" />
                    </div>

                    <div class="alert alert-warning"
                        role="alert"
                        invisible="restaurant_product_type != 'combo' or not combo_is_valid or not combo_is_available or not combo_cost_warning">
                        <strong>Combo cost warning.</strong>
                        <br />
                        <field name="combo_cost_warning_message" readonly="1" nolabel="1" />
                    </div>
                    <group>
                        <group string="Combo Financial Summary">
                            <group>
                                <field name="combo_component_count" readonly="1" />
                                <field name="combo_individual_total_price" readonly="1" />
                                <field name="combo_saving_amount" readonly="1" />
                            </group>

                        </group>

                        <group string="Combo Cost Summary">
                            <group>
                                <field name="combo_total_cost" readonly="1" />
                                <field name="combo_food_cost_percentage" readonly="1" />
                            </group>

                        </group>

                    </group>
                    <group string="Combo Component Lines">
                        <field name="combo_component_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle" />
                                <field name="component_product_tmpl_id" />
                                <field name="quantity" />
                                <field name="allow_customization" />
                                <field name="is_swappable" />
                                <field name="allowed_substitute_product_ids"
                                    widget="many2many_tags"
                                    invisible="not is_swappable" />
                                <field name="is_upgradeable" />
                                <field name="upgrade_price"
                                    invisible="not is_upgradeable" />
                                <field name="notes" />
                            </list>
                        </field>
                    </group>

                </page>

                <page string="Branch Availability" name="branch_availability" invisible="not is_menu_item">
                    <field name="allowed_branch_ids" invisible="1"/>
                    <field name="branch_availability_selectable_branch_ids" invisible="1"/>
                    <div class="alert alert-info" role="alert">
                        <strong>Branch availability summary</strong>
                        <br/>
                        <field name="branch_availability_summary" readonly="1" nolabel="1"/>
                        <br invisible="not branch_availability_date_summary"/>
                        <field name="branch_availability_date_summary"
                               readonly="1"
                               nolabel="1"
                               invisible="not branch_availability_date_summary"/>
                        <hr class="my-2"/>
                        <span class="text-muted">Branch availability controls where this product can be offered. Product active/sellable status still applies globally.</span>
                    </div>
                    <group>
                        <group string="Availability Rule">
                            <field name="can_edit_global_branch_availability" invisible="1"/>
                            <field name="branch_availability_mode" widget="radio" readonly="not can_edit_global_branch_availability" />
                            <label for="branch_available_from" string="Availability Dates"/>
                            <div class="o_row">
                                <field name="branch_available_from" class="oe_inline" placeholder="Start Date" readonly="not can_edit_global_branch_availability" />
                                <span>to</span>
                                <field name="branch_available_until" class="oe_inline" placeholder="End Date" readonly="not can_edit_global_branch_availability" />
                            </div>
                        </group>
                        <group string="Availability Reason">
                            <field name="branch_unavailable_reason" placeholder="Reason why this item is unavailable at certain branches..." readonly="not can_edit_global_branch_availability" />
                        </group>
                    </group>
                    <group string="Selected Branches" invisible="branch_availability_mode != 'selected_branches'">
                        <field name="branch_available_ids" widget="many2many_tags" nolabel="1" options="{'no_create': True}" domain="[('id', 'in', branch_availability_selectable_branch_ids)]"/>
                    </group>
                    <group string="Excluded Branches" invisible="branch_availability_mode != 'excluded_branches'">
                        <field name="branch_excluded_ids" widget="many2many_tags" nolabel="1" options="{'no_create': True}" domain="[('id', 'in', branch_availability_selectable_branch_ids)]"/>
                    </group>
                    <group string="Audit" name="availability_audit">
                        <group>
                            <field name="branch_availability_last_changed_by" />
                            <field name="branch_availability_last_changed_on" />
                        </group>
                    </group>
                    <group string="Change History (Audit Log)" name="change_history">
                        <field name="branch_availability_log_ids" readonly="1" nolabel="1">
                            <list create="0" edit="0" delete="0">
                                <field name="changed_on" />
                                <field name="changed_by_id" />
                                <field name="change_summary" />
                            </list>
                        </field>
                    </group>
                </page>

                <page string="Branch Pricing" name="branch_pricing" invisible="not is_menu_item">
                    <field name="branch_pricing_has_below_cost" invisible="1"/>
                    <field name="branch_pricing_has_future_rules" invisible="1"/>
                    <field name="branch_pricing_summary" invisible="1"/>
                    <div class="alert alert-info" role="alert">
                        <strong>Branch Pricing Summary:</strong> <field name="branch_pricing_summary" readonly="1" nolabel="1"/>
                        <br/>
                        <span class="text-muted">If no branch/channel price rule applies, the product Sales Price is used.</span>
                    </div>
                    <div class="alert alert-info" role="alert" invisible="not branch_pricing_has_future_rules">
                        This product has scheduled future branch/channel price changes.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="not branch_pricing_has_below_cost">
                        Some branch/channel prices are below current cost.
                    </div>
                    <field name="branch_price_line_ids" nolabel="1">
                        <list editable="bottom" decoration-danger="is_below_cost">
                            <field name="sequence" widget="handle" />
                            <field name="company_id" column_invisible="True" />
                            <field name="currency_id" column_invisible="True" />
                            <field name="allowed_branch_ids" column_invisible="True" />
                            <field name="is_below_cost" column_invisible="True" />
                            <field name="branch_id" options="{'no_create': True}" domain="[('company_id', 'in', (parent.company_id, False))]" />
                            <field name="channel" />
                            <field name="price" />
                            <field name="cost_reference" readonly="1" force_save="1" />
                            <field name="date_from" />
                            <field name="date_until" />
                            <field name="active" />
                            <field name="note" />
                        </list>
                    </field>
                    <group string="Price History (Audit Log)" name="branch_pricing_history">
                        <field name="branch_price_history_ids" readonly="1" nolabel="1">
                            <list create="0" edit="0" delete="0">
                                <field name="company_id" column_invisible="True" />
                                <field name="currency_id" column_invisible="True" />
                                <field name="changed_on" />
                                <field name="changed_by_id" />
                                <field name="branch_id" />
                                <field name="channel" />
                                <field name="old_price" />
                                <field name="new_price" />
                                <field name="change_summary" />
                            </list>
                        </field>
                    </group>
                </page>
                <page string="Menu Scheduling" name="menu_scheduling" invisible="not is_menu_item">
                    <field name="product_schedule_line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="schedule_rule_id" options="{'no_create': True}" domain="[('company_id', 'in', (company_id, False))]"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1" force_save="1"/>
                            <field name="branch_id" options="{'no_create': True}" domain="[('company_id', '=', company_id)]"/>
                            <field name="active" widget="boolean_toggle"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="product_template_search_view_restaurant_menu" model="ir.ui.view">
        <field name="name">product.template.search.restaurant.menu</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='combo']" position="after">
                <filter string="Combo Meals" name="combo_meals"
                    domain="[('restaurant_product_type', '=', 'combo')]" />
            </xpath>
            <xpath expr="//filter[@name='combo_meals']" position="after">
                <filter string="Branch Restricted" name="branch_restricted"
                    domain="['|', ('branch_availability_mode', '!=', 'all_branches'), '|', ('branch_available_from', '!=', False), ('branch_available_until', '!=', False)]" />
                <separator/>
                <filter string="Has Branch Pricing" name="has_branch_pricing" domain="[('branch_pricing_has_active_rules', '=', True)]"/>
                <filter string="Scheduled Branch Price Changes" name="scheduled_branch_price_changes" domain="[('branch_pricing_has_future_rules', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_kanban_view_restaurant_menu" model="ir.ui.view">
        <field name="name">product.template.kanban.restaurant.menu</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view" />
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="inside">
                <field name="restaurant_product_type" />
                <field name="combo_is_valid" />
                <field name="combo_is_available" />
                <field name="combo_cost_warning" />
                <field name="is_menu_item" />
                <field name="branch_availability_has_restriction" />
                <field name="branch_availability_summary" />
                <field name="branch_pricing_has_active_rules" />
                <field name="branch_pricing_has_below_cost" />
                <field name="branch_pricing_has_future_rules" />
            </xpath>
            <xpath expr="//t[@t-name='card']/main/div[1]" position="inside">
                <div t-if="record.restaurant_product_type.raw_value == 'combo'" class="d-flex flex-wrap gap-1 mt-1">
                    <span t-if="!record.combo_is_valid.raw_value" class="badge text-bg-warning">Combo Meal is not ready to sell.</span>
                    <span t-if="record.combo_is_valid.raw_value and !record.combo_is_available.raw_value" class="badge text-bg-danger">Combo Meal is currently unavailable.</span>
                    <span t-if="record.combo_is_valid.raw_value and record.combo_is_available.raw_value and record.combo_cost_warning.raw_value" class="badge text-bg-warning">Combo cost warning.</span>
                </div>
                <div t-if="record.is_menu_item.raw_value and record.branch_availability_has_restriction.raw_value" class="d-flex flex-wrap gap-1 mt-1">
                    <span class="badge text-bg-warning" t-att-title="record.branch_availability_summary.raw_value">Branch Restricted</span>
                </div>
                <div t-if="record.is_menu_item.raw_value and record.branch_pricing_has_active_rules.raw_value" class="d-flex flex-wrap gap-1 mt-1">
                    <span class="badge text-bg-info">Branch Pricing</span>
                    <span t-if="record.branch_pricing_has_below_cost.raw_value" class="badge text-bg-danger">Below Cost</span>
                    <span t-if="record.branch_pricing_has_future_rules.raw_value" class="badge text-bg-primary">Future Price</span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>