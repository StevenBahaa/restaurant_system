<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view_restaurant_menu" model="ir.ui.view">
        <field name="name">product.template.form.restaurant.menu</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']//group" position="inside">
                <group string="Restaurant ERP">
                    <group string="Menu Identity">
                        <field name="is_menu_item" />
                        <field name="arabic_name" invisible="not is_menu_item" />
                    </group>

                    <group string="Restaurant Classification">
                        <field name="restaurant_product_type" />
                    </group>
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Add-ons" name="restaurant_addons" invisible="not is_menu_item">

                    <group string="Add-on Groups">
                        <field name="product_addon_group_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle" />
                                <field name="addon_group_id" />
                                <field name="required_override" />
                                <field name="override_selection_rules" />
                                <field name="min_selection"
                                    invisible="not override_selection_rules" />
                                <field name="max_selection"
                                    invisible="not override_selection_rules" />
                                <field name="active" />
                            </list>
                        </field>
                    </group>

                </page>
            </xpath>
        </field>
    </record>
</odoo>