<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="restaurant_addon_group_view_list" model="ir.ui.view">
        <field name="name">restaurant.addon.group.view.list</field>
        <field name="model">restaurant.addon.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="active" />
            </list>
        </field>
    </record>

    <record id="restaurant_addon_group_view_form" model="ir.ui.view">
        <field name="name">restaurant.addon.group.view.form</field>
        <field name="model">restaurant.addon.group</field>
        <field name="arch" type="xml">
            <form string="Add-on Group">
                <sheet>
                    <group>
                        <field name="name" readonly="used_in_operations" />
                        <field name="active" />
                        <field name="used_in_operations" readonly="1" />
                    </group>

                    <notebook>
                        <page string="Add-ons">
                            <field name="addon_item_ids">
                                <list>
                                    <field name="product_tmpl_id" readonly="used_in_operations" />
                                    <field name="additional_price" readonly="used_in_operations" />
                                    <field name="addon_cost" readonly="1" />
                                    <field name="max_quantity" readonly="used_in_operations" />
                                    <field name="kitchen_note" readonly="used_in_operations" />
                                    <field name="active" />
                                    <field name="used_in_operations" readonly="1" />
                                </list>

                                <form string="Add-on Item">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="product_tmpl_id" />
                                                <field name="additional_price" />
                                                <field name="addon_cost" readonly="1" />
                                            </group>

                                            <group>
                                                <field name="max_quantity" />
                                                <field name="kitchen_note" />
                                                <field name="active" />
                                                <field name="used_in_operations" readonly="1" />
                                            </group>
                                        </group>

                                        <notebook>
                                            <page string="Ingredient Consumption">
                                                <field name="ingredient_line_ids"
                                                    readonly="used_in_operations">
                                                    <list editable="bottom">
                                                        <field name="ingredient_product_id" />
                                                        <field name="quantity" />
                                                        <field name="uom_id" />
                                                        <field name="wastage_percent" />
                                                        <field name="actual_quantity" readonly="1" />
                                                        <field name="ingredient_cost" readonly="1" />
                                                        <field name="line_cost" readonly="1" />
                                                    </list>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="restaurant_addon_group_action" model="ir.actions.act_window">
        <field name="name">Add-on Groups</field>
        <field name="res_model">restaurant.addon.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="restaurant_addon_group_menu"
        name="Add-on Groups"
        parent="restaurant_base.restaurant_menu_configuration"
        action="restaurant_addon_group_action"
        sequence="30" />

</odoo>