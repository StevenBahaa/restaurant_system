<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_restaurant_pricing_manager" model="res.groups">
            <field name="name">Restaurant Pricing Manager</field>
            <field name="category_id" ref="restaurant_base.module_category_restaurant"/>
            <field name="comment">Can manage branch-specific pricing rules.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="restaurant_schedule_rule_comp_rule" model="ir.rule">
            <field name="name">Restaurant Schedule Rule Multi-Company</field>
            <field name="model_id" ref="model_restaurant_schedule_rule"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="restaurant_product_schedule_line_comp_rule" model="ir.rule">
            <field name="name">Restaurant Product Schedule Line Multi-Company</field>
            <field name="model_id" ref="model_restaurant_product_schedule_line"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="restaurant_category_schedule_line_comp_rule" model="ir.rule">
            <field name="name">Restaurant Category Schedule Line Multi-Company</field>
            <field name="model_id" ref="model_restaurant_category_schedule_line"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="restaurant_schedule_override_comp_rule" model="ir.rule">
            <field name="name">Restaurant Schedule Override Multi-Company</field>
            <field name="model_id" ref="model_restaurant_schedule_override"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
    </data>
</odoo>
