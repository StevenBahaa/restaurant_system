<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="restaurant_recipe_view_form_inherit_inventory" model="ir.ui.view">
        <field name="name">restaurant.recipe.view.form.inherit.inventory</field>
        <field name="model">restaurant.recipe</field>
        <field name="inherit_id" ref="restaurant_recipe.restaurant_recipe_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='recipe_line_ids']/list/field[@name='quantity']" position="before">
                <field name="is_critical" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
