<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view_restaurant_recipe" model="ir.ui.view">
        <field name="name">product.template.form.restaurant.recipe</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_recipes"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-cutlery"
                    invisible="not is_menu_item">
                    <field name="recipe_count" widget="statinfo" string="Recipes" />
                </button>
            </xpath>

            <xpath expr="//page[@name='general_information']//group" position="inside">
                <group string="Recipe &amp; Costing" invisible="not is_menu_item">
                    <field name="recipe_cost" readonly="1" />
                </group>
            </xpath>

        </field>
    </record>
</odoo>