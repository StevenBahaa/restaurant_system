<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_restaurant_kitchen" model="ir.ui.view">
        <field name="name">product.template.form.restaurant.kitchen</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Kitchen Stations" name="kitchen_stations" invisible="not is_menu_item or restaurant_product_type not in ['prepared_meal', 'beverage', 'ready_item']">
                    <field name="kitchen_station_line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="station_id" options="{'no_create': True}" domain="[('company_id', '=', company_id)]"/>
                            <field name="expected_prep_time"/>
                            <field name="active" widget="boolean_toggle"/>
                            <field name="note"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
